# =============================================================================
# sprinkler-ai secrets — copy to .env and fill in. Never commit .env.
# =============================================================================

# ── Rainbird controller (REQUIRED) ───────────────────────────────────────────
# IP of the LNK Wi-Fi adapter on your local network, and the controller password
# you set in the Rainbird app.
RAINBIRD_HOST=
RAINBIRD_PASSWORD=

# ── Claude / Gemini CLI (REQUIRED — the planner shells out to these) ─────────
# Path to the `claude` CLI binary. Install from https://claude.ai/code.
# Leave as just "claude" if it's on your PATH.
CLAUDE_BIN=claude
# Optional fallback — only used if Claude fails. Install from gemini.google.com/cli.
GEMINI_BIN=gemini

# ── Ecowitt soil-moisture gateway (OPTIONAL) ─────────────────────────────────
# Local IP of a GW1200/GW2000 with WH51 soil probes. Find in WSView Plus →
# device → local network. Leave empty to disable.
ECOWITT_HOST=

# ── Discord bot for on-demand lawn diagnosis (OPTIONAL) ──────────────────────
# Create a bot at https://discord.com/developers/applications → Bot → Reset Token.
# MUST enable "MESSAGE CONTENT INTENT" on the Bot page.
DISCORD_BOT_TOKEN=
# Optional — restrict the bot to one channel. Right-click channel → Copy Channel
# ID (requires Developer Mode in Discord settings). Leave unset to listen everywhere.
DISCORD_DIAGNOSE_CHANNEL_ID=

# ── Nest cameras (OPTIONAL — for daylight lawn vision analysis) ──────────────
# See docs/nest-setup.md for the full Google Device Access walkthrough.
# Requires a one-time $5 fee for the Device Access project.
NEST_PROJECT_ID=
NEST_CLIENT_ID=
NEST_CLIENT_SECRET=
NEST_REFRESH_TOKEN=
